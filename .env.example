# ============================================================
# 小杰AI选股系统 — 环境变量配置（不要将此文件提交到 Git！）
# ============================================================
# 第一次运行系统时，会自动引导你填写以下 key。
# 填写后本文件会自动生成（从 .env.example 复制），之后无需再填。
#
# 优先级：环境变量 > .env 文件 > config.yaml 占位符
# ============================================================

# Tushare Pro Token（从 https://tushare.pro/register 注册后获取）
# 不需要 http 前缀，直接填入 token 字符串即可
TUSHARE_TOKEN=

# DeepSeek API Key（用于 AI 选股分析建议，可选；sk- 开头，从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=

# 企微 Webhook URL（用于推送选股结果和系统告警，可选）
# 主地址：用于 P1~P5 选股推送
WEIXIN_WEBHOOK_URL=
# 次地址：用于维护、下载、报错、任务执行结果等系统消息
WEIXIN_WEBHOOK_URL_SECONDARY=
